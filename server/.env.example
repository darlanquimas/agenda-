# Ambiente
NODE_ENV=production

# Servidor
PORT=3009
CLIENT_URL=https://agendaplus.dquimas.com.br

# Banco de dados PostgreSQL
DATABASE_URL=postgres://postgres:asdugf75b@database:5432/agendaplus

# Autenticação JWT (obrigatório em production — use valor longo e aleatório)
JWT_SECRET=584b4f5e6d912e4480b4d287d4dc5b44
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Configuration
COOKIE_SECRET=584b4f5e6d912e4480b4d287d4dc5b44
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=.dquimas.com.br
# COOKIE_DOMAIN=.example.com (use em produção para subdomínios)

# Security Features
ENABLE_CSRF=true
ENABLE_2FA=true

# Limites HTTP
JSON_BODY_LIMIT=100kb

# Rate Limiting (janela em ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=20
RATE_LIMIT_MAX_BOOKING=30
RATE_LIMIT_MAX_API=500

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_MIN_LENGTH=12

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Evo Manager Plus (gateway WhatsApp) — URL base do gateway, compartilhada por todos
# os tenants. Client ID, API Key e webhook signing secret NÃO ficam aqui: são por
# tenant, configurados na tela de WhatsApp do próprio Agenda+ (tabela whatsapp_config).
EVO_MANAGER_API_URL=https://api-evo.dquimas.com.br/api/v1

WEBHOOK_BASE_URL=https://api-agenda.dquimas.com.br

# Token Configuration
CONFIRMATION_TOKEN_EXPIRATION_HOURS=48
