# Ambiente
NODE_ENV=development

# Servidor
PORT=3001
CLIENT_URL=http://localhost:5173

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/baba_db

# Autenticação JWT (obrigatório em production — use valor longo e aleatório)
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Configuration
COOKIE_SECRET=
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=
# COOKIE_DOMAIN=.example.com (use em produção para subdomínios)

# Security Features
ENABLE_CSRF=true
ENABLE_2FA=true

# Limites HTTP
JSON_BODY_LIMIT=100kb

# Rate Limiting (janela em ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=20
RATE_LIMIT_MAX_BOOKING=30
RATE_LIMIT_MAX_API=500

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_MIN_LENGTH=12

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Evolution API Configuration
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
WEBHOOK_BASE_URL=http://localhost:3001

# Webhook Security (CRÍTICO: gere um valor aleatório longo em produção)
WEBHOOK_SECRET=
# Use: openssl rand -hex 32

# Token Configuration
CONFIRMATION_TOKEN_EXPIRATION_HOURS=48
