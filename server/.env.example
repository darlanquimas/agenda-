# Ambiente
NODE_ENV=production

# Servidor
PORT=3009
CLIENT_URL=https://agendaplus.dquimas.com.br

# Banco de dados PostgreSQL
DATABASE_URL=postgres://postgres:asdugf75b@database:5432/agendaplus

# Autenticação JWT (obrigatório em production — use valor longo e aleatório)
JWT_SECRET=584b4f5e6d912e4480b4d287d4dc5b44
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie Configuration
COOKIE_SECRET=584b4f5e6d912e4480b4d287d4dc5b44
COOKIE_SAME_SITE=strict
COOKIE_DOMAIN=.dquimas.com.br
# COOKIE_DOMAIN=.example.com (use em produção para subdomínios)

# Security Features
ENABLE_CSRF=true
ENABLE_2FA=true

# Limites HTTP
JSON_BODY_LIMIT=100kb

# Rate Limiting (janela em ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=20
RATE_LIMIT_MAX_BOOKING=30
RATE_LIMIT_MAX_API=500

# Account Security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
PASSWORD_MIN_LENGTH=12

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# Evolution API Configuration
EVOLUTION_API_URL=http://evolution-api:5062

EVOLUTION_API_KEY=429683C4C977415CAAFCCE10F7D57E11
WEBHOOK_BASE_URL=https://api-agenda.dquimas.com.br

# Webhook Security (CRÍTICO: gere um valor aleatório longo em produção)
WEBHOOK_SECRET=584b4f5e6d912e4480b4d287d4dc5b4412ab9b9b7b2a5ceb15282dfa53dd8136
# Use: openssl rand -hex 32

# Token Configuration
CONFIRMATION_TOKEN_EXPIRATION_HOURS=48
