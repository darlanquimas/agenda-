# Ambiente
NODE_ENV=development

# Servidor
PORT=3001
CLIENT_URL=http://localhost:5173

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/baba_db

# Autenticação (obrigatório em production — use valor longo e aleatório)
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Limites HTTP
JSON_BODY_LIMIT=100kb

# Rate limiting (janela em ms)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_LOGIN=20
RATE_LIMIT_MAX_BOOKING=30
